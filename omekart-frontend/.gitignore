# ============================================
# Omekart .gitignore
# ============================================

# ==========================
# Dependencies
# ==========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==========================
# Next.js
# ==========================
.next/
out/
build/

# ==========================
# Production Builds
# ==========================
dist/
coverage/

# ==========================
# Environment Variables
# ==========================
.env
.env.*
.env.local
.env.local.bak
.env.development
.env.production
.env.test

# ==========================
# Supabase Local Development
# ==========================
.supabase/
supabase/.temp/

# ==========================
# Vercel
# ==========================
.vercel/

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# TypeScript
# ==========================
*.tsbuildinfo
next-env.d.ts

# ==========================
# Operating System
# ==========================
.DS_Store
Thumbs.db
Desktop.ini

# ==========================
# IDEs
# ==========================
.vscode/
.idea/
*.swp
*.swo

# ==========================
# Certificates & Keys
# ==========================
*.pem
*.key
*.crt
*.p12

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
.cache/
*.tmp

# ==========================
# Archives & Backups
# ==========================
*.zip
*.tar
*.gz
*.7z
*.bak
*.old

# ==========================
# Local SQLite Databases
# ==========================
*.sqlite
*.sqlite3
*.db

# ==========================
# Miscellaneous
# ==========================
.eslintcache
.vercel
